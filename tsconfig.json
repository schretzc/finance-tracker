{
	"compilerOptions": {
		"rootDir": "./", // Change from ./src to ./ so it sees root files
		"outDir": "./dist",

		"module": "node16",
		"moduleResolution": "node16",
		"target": "es2020",
		"types": ["node"],

		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,

		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"strict": true,
		"skipLibCheck": true
	},

	"include": [
		"src/**/*",
		"prisma.config.ts", // 👈 Add this specifically
		".env" // Optional, but helpful
	],
	"exclude": ["node_modules", "dist"]
}
