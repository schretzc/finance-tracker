{
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",

		"module": "node16",
		"moduleResolution": "node16",
		"target": "es2020",
		"types": ["node"],

		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,

		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"strict": true,
		"skipLibCheck": true
	},

	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
